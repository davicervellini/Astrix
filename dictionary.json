          "en": "good"
        }
      }
    },
    "adverbs_interjections": {
      "salu": {
        "translations": {
          "pt": "olá / saudações",
          "en": "hello / greetings"
        },
        "examples": [
          {
            "text": "Salu, partnoro!",
            "translation_pt": "Olá, parceiro!",
            "translation_en": "Hello, partner!"
          }
        ]
      },
      "vayu": {
        "translations": {
          "pt": "adeus",
