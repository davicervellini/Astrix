{
  "language": "Astrix",
  "version": "0.3",
  "description": "Língua construída otimizada para a era interestelar",
  "categories": {
    "adjectives": {
      "grandi": {
        "translations": {
          "pt": "grande",
          "en": "big / large"
        }
      },
      "rapidi": {
        "translations": {
          "pt": "rápido",
          "en": "fast / quick"
        }
      },
      "forti": {
        "translations": {
          "pt": "forte",
          "en": "strong"
        }
      },
      "kuriosi": {
        "translations": {
          "pt": "curioso",
          "en": "curious"
